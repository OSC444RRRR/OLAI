<section class="simple-contact-page">
  <div class="container simple-contact-box">
    <div class="section-heading reveal visible center">
      <span class="section-label">Contacto</span>
      <h1>Hablemos de tu proyecto</h1>
      <p>Compártenos qué quieres optimizar. También puedes escribirnos a <a href="mailto:olai.digital.mx@gmail.com">olai.digital.mx@gmail.com</a>.</p>
    </div>

    <div class="contact-form-box reveal visible delay-1">
      {% form 'contact', class: 'contact-form' %}
        <div class="field-row">
          <input type="text" name="contact[name]" placeholder="Nombre" required>
          <input type="email" name="contact[email]" placeholder="Correo" required>
        </div>
        <input type="text" name="contact[company]" placeholder="Empresa">
        <textarea name="contact[body]" placeholder="Describe tu proyecto" required></textarea>
        <button type="submit" class="btn btn-primary full">Enviar</button>
        {% if form.posted_successfully? %}
          <p class="form-message success">Gracias, recibimos tu mensaje.</p>
        {% endif %}
        {% if form.errors %}
          <p class="form-message error">Revisa los datos e inténtalo de nuevo.</p>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{ "name": "OLAI contact", "settings": [] }
{% endschema %}