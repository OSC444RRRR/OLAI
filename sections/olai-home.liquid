<section class="olai-site">
  <div class="bg-grid"></div>
  <div class="bg-orb orb-1"></div>
  <div class="bg-orb orb-2"></div>

  <header class="site-header">
    <div class="container nav-shell">
      <a href="{{ routes.root_url }}" class="brand" aria-label="OLAI">
        <span class="brand-mark">O</span>
        <span class="brand-copy">
          <span class="brand-title">OLAI</span>
          <span class="brand-sub">Optimización empresarial premium</span>
        </span>
      </a>
      <button class="menu-toggle" type="button" aria-label="Abrir menú" data-menu-toggle>
        <span></span><span></span><span></span>
      </button>
      <nav class="main-nav" data-menu>
        <a href="#servicios">Servicios</a>
        <a href="#soluciones">Soluciones</a>
        <a href="#proceso">Proceso</a>
        <a href="#contacto">Contacto</a>
      </nav>
      <div class="nav-cta desktop-only">
        <a href="#contacto" class="btn btn-secondary">Solicitar propuesta</a>
      </div>
    </div>
  </header>

  <section class="hero section-first">
    <div class="container hero-grid">
      <div class="hero-copy reveal is-visible">
        <span class="eyebrow">IA aplicada, automatización y páginas web personalizadas</span>
        <h1>Optimizamos servicios y empresas con IA, automatización e interfaces web hechas a la medida.</h1>
        <p class="lead">En OLAI creamos soluciones digitales para empresas que quieren trabajar con más orden, menos tareas manuales y una presencia web alineada a su nivel de servicio.</p>
        <div class="hero-actions">
          <a href="#contacto" class="btn btn-primary">Solicitar propuesta</a>
          <a href="#servicios" class="btn btn-secondary">Ver servicios</a>
        </div>
        <div class="metrics-grid">
          <article class="metric-card reveal"><strong>Optimización con IA</strong><span>Automatización, clasificación, seguimiento y mejora operativa.</span></article>
          <article class="metric-card reveal delay-1"><strong>Web personalizada</strong><span>Páginas adaptadas al cliente, al servicio y al objetivo comercial.</span></article>
          <article class="metric-card reveal delay-2"><strong>Integración real</strong><span>CRM, formularios, correo, dashboards y herramientas conectadas.</span></article>
        </div>
      </div>
      <div class="hero-panel reveal delay-2">
        <div class="glass-card system-card">
          <div class="card-top">
            <div>
              <p class="mini-label">Sistema OLAI</p>
              <h2>Soluciones premium que sí aterrizan</h2>
            </div>
            <span class="chip">Escalable</span>
          </div>
          <div class="flow-list">
            <div class="flow-item"><span class="flow-step">1</span><div><strong>Diagnóstico</strong><p>Entendemos la operación y el problema real del cliente.</p></div></div>
            <div class="flow-item"><span class="flow-step">2</span><div><strong>Diseño</strong><p>Definimos tecnología, automatización, IA y estructura web.</p></div></div>
            <div class="flow-item"><span class="flow-step">3</span><div><strong>Implementación</strong><p>Construimos una solución funcional y adaptada al negocio.</p></div></div>
            <div class="flow-item"><span class="flow-step">4</span><div><strong>Optimización</strong><p>Ajustamos y mejoramos para que el sistema escale mejor.</p></div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="trust-strip">
    <div class="container trust-box reveal">
      <span>Servicios para empresas que quieren operar mejor, verse mejor y crecer con estructura.</span>
      <div class="trust-tags">
        <span>IA</span><span>Automatización</span><span>Integraciones</span><span>Web premium</span>
      </div>
    </div>
  </section>

  <section id="servicios" class="section">
    <div class="container">
      <div class="section-head reveal">
        <span class="section-kicker">Servicios</span>
        <h2>Una solución profesional para cada necesidad del cliente</h2>
        <p>No trabajamos con una sola plantilla. Diseñamos servicios digitales según la operación, el objetivo y el nivel de la empresa.</p>
      </div>
      <div class="cards-grid two-col">
        <article class="info-card reveal"><small>01</small><h3>Optimización con IA</h3><p>Automatizamos tareas, seguimiento, clasificación de solicitudes y procesos repetitivos.</p></article>
        <article class="info-card reveal delay-1"><small>02</small><h3>Automatización operativa</h3><p>Reducimos fricción entre áreas, tareas y herramientas para que la operación fluya mejor.</p></article>
        <article class="info-card reveal delay-2"><small>03</small><h3>Páginas web personalizadas</h3><p>Desarrollamos páginas premium alineadas a la identidad y objetivos del cliente.</p></article>
        <article class="info-card reveal delay-3"><small>04</small><h3>Integraciones</h3><p>Conectamos formularios, correo, dashboards, CRM y otras herramientas clave.</p></article>
      </div>
    </div>
  </section>

  <section id="soluciones" class="section section-alt">
    <div class="container">
      <div class="section-head reveal">
        <span class="section-kicker">Soluciones</span>
        <h2>Qué ayudamos a corregir en una empresa</h2>
      </div>
      <div class="cards-grid three-col">
        <article class="benefit-card reveal"><strong>Procesos lentos</strong><p>Menos trabajo manual, menos duplicidad y más claridad operativa.</p></article>
        <article class="benefit-card reveal delay-1"><strong>Seguimiento inconsistente</strong><p>Más orden comercial y mejor atención para prospectos y clientes.</p></article>
        <article class="benefit-card reveal delay-2"><strong>Presencia digital débil</strong><p>Una web mejor pensada mejora percepción, confianza y conversión.</p></article>
      </div>
    </div>
  </section>

  <section id="proceso" class="section">
    <div class="container split-layout">
      <div class="section-head reveal">
        <span class="section-kicker">Proceso</span>
        <h2>Cómo trabaja OLAI</h2>
        <p>Un proceso claro permite que la solución final se vea bien y también funcione bien.</p>
      </div>
      <div class="steps-list">
        <article class="step-card reveal"><span>1</span><div><h3>Escuchamos</h3><p>Analizamos el servicio, el flujo y la meta del proyecto.</p></div></article>
        <article class="step-card reveal delay-1"><span>2</span><div><h3>Planeamos</h3><p>Definimos estructura, automatización, integraciones y experiencia.</p></div></article>
        <article class="step-card reveal delay-2"><span>3</span><div><h3>Construimos</h3><p>Desarrollamos una solución adaptada al cliente y su negocio.</p></div></article>
        <article class="step-card reveal delay-3"><span>4</span><div><h3>Refinamos</h3><p>Optimizamos la ejecución para que el sistema escale mejor.</p></div></article>
      </div>
    </div>
  </section>

  <section id="contacto" class="section section-contact">
    <div class="container contact-shell reveal is-visible">
      <div class="contact-copy">
        <span class="section-kicker dark">Contacto</span>
        <h2>Cuéntanos qué quieres optimizar</h2>
        <p>Si quieres mejorar procesos con IA o lanzar una página web premium para tu negocio, podemos ayudarte a diseñar una propuesta clara y funcional.</p>
        <ul class="contact-points" role="list">
          <li>Automatización con IA.</li>
          <li>Páginas web personalizadas.</li>
          <li>Integración de herramientas.</li>
        </ul>
      </div>
      <div class="contact-form-wrap">
        {% form 'contact', class: 'contact-form' %}
          <div class="field-row">
            <input type="text" name="contact[name]" placeholder="Nombre" required>
            <input type="email" name="contact[email]" placeholder="Correo" required>
          </div>
          <input type="text" name="contact[company]" placeholder="Empresa">
          <textarea name="contact[body]" placeholder="Cuéntanos qué servicio necesitas" required></textarea>
          <button type="submit" class="btn btn-dark full">Enviar solicitud</button>
          {% if form.posted_successfully? %}<p class="form-message success">Gracias, recibimos tu mensaje.</p>{% endif %}
          {% if form.errors %}<p class="form-message error">Revisa los datos e inténtalo de nuevo.</p>{% endif %}
        {% endform %}
      </div>
    </div>
  </section>
</section>

{% schema %}
{
  "name": "OLAI home",
  "settings": [],
  "presets": [{ "name": "OLAI home" }]
}
{% endschema %}