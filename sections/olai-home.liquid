<section class="olai-site">
  <div class="bg-blur bg-blur-a"></div>
  <div class="bg-blur bg-blur-b"></div>

  <header class="site-header">
    <div class="container header-shell">
      <a href="{{ routes.root_url }}" class="brand" aria-label="OLAI inicio">
        <img src="{{ 'olai.jpg' | asset_url }}" alt="Logo OLAI" class="brand-logo" width="56" height="56">
        <div class="brand-text">
          <strong>OLAI</strong>
          <span>Automatización Inteligente</span>
        </div>
      </a>

      <button class="menu-toggle" type="button" data-menu-toggle aria-label="Abrir menú">
        <span></span><span></span><span></span>
      </button>

      <nav class="main-nav" data-menu>
        <a href="#servicios">Servicios</a>
        <a href="#ventajas">Ventajas</a>
        <a href="#proceso">Proceso</a>
        <a href="#contacto">Contacto</a>
      </nav>

      <a href="#contacto" class="btn btn-primary desktop-cta">Solicitar propuesta</a>
    </div>
  </header>

  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy reveal visible">
        <h1>Hacemos que tu empresa opere mejor y proyecte una imagen más profesional.</h1>
        <p class="hero-text"><h2>En OLAI desarrollamos soluciones de automatización con inteligencia artificial, integraciones y páginas web personalizadas para empresas que quieren reducir fricción, mejorar seguimiento y crecer con una estructura digital más sólida.<h2></p>

        <div class="hero-actions">
          <a href="#contacto" class="btn btn-primary">Solicitar propuesta</a>
          <a href="#servicios" class="btn btn-secondary">Ver servicios</a>
        </div>

        <div class="hero-tags">
          <span>Optimización operativa</span>
          <span>Automatización con IA</span>
          <span>Web personalizada</span>
        </div>
      </div>

      <div class="hero-card reveal delay-1 visible">
        <div class="panel-card">
          <span class="panel-label">Arquitectura OLAI</span>
          <h2>De procesos dispersos a una operación más clara, conectada y escalable.</h2>

          <div class="panel-steps">
            <article>
              <strong>Diagnóstico</strong>
              <p>Identificamos cuellos de botella, retrabajos, tareas manuales y oportunidades reales de optimización.</p>
            </article>
            <article>
              <strong>Diseño</strong>
              <p>Definimos automatización, integración, IA y experiencia web según la necesidad del negocio.</p>
            </article>
            <article>
              <strong>Implementación</strong>
              <p>Construimos una solución adaptada al cliente, con foco en utilidad, orden y presentación.</p>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section compact-top" id="servicios">
    <div class="container">
      <div class="section-heading reveal">
        <span class="section-label">Servicios</span>
        <h2>Soluciones digitales pensadas para negocio, operación y crecimiento.</h2>
        <p>No trabajamos con soluciones genéricas. Diseñamos una estructura digital alineada al servicio, al proceso y al objetivo comercial del cliente.</p>
      </div>

      <div class="cards-grid two-col">
        <article class="info-card reveal">
          <small>01</small>
          <h3>Optimización con IA</h3>
          <p>Automatizamos tareas, clasificación, seguimiento y procesos repetitivos para reducir carga operativa.</p>
        </article>
        <article class="info-card reveal delay-1">
          <small>02</small>
          <h3>Automatización operativa</h3>
          <p>Conectamos procesos y herramientas para que la operación sea más fluida, ordenada y medible.</p>
        </article>
        <article class="info-card reveal delay-2">
          <small>03</small>
          <h3>Páginas web personalizadas</h3>
          <p>Diseñamos páginas premium adaptadas al servicio, a la marca y a la percepción que quieres proyectar.</p>
        </article>
        <article class="info-card reveal delay-3">
          <small>04</small>
          <h3>Integraciones</h3>
          <p>Conectamos formularios, correo, CRM, dashboards y otros sistemas para crear flujos reales de trabajo.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-soft" id="ventajas">
    <div class="container">
      <div class="section-heading reveal center">
        <span class="section-label">Ventajas</span>
        <h2>Diseño, operación y tecnología trabajando juntos.</h2>
      </div>

      <div class="cards-grid two-col advantages-grid">
        <article class="soft-card reveal">
          <h3>Menos trabajo manual</h3>
          <p>Reducimos fricción operativa y tareas repetitivas.</p>
        </article>
        <article class="soft-card reveal delay-1">
          <h3>Más claridad interna</h3>
          <p>Procesos conectados, mejor seguimiento y más control.</p>
        </article>
        <article class="soft-card reveal delay-2">
          <h3>Mejor presencia digital</h3>
          <p>Una web premium mejora percepción, confianza y comunicación.</p>
        </article>
        <article class="soft-card reveal delay-3">
          <h3>Solución adaptada</h3>
          <p>Cada propuesta se diseña según el contexto real del cliente.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="proceso">
    <div class="container">
      <div class="section-heading reveal center">
        <span class="section-label">Proceso</span>
        <h2>Cómo trabajamos en OLAI</h2>
      </div>

      <div class="process-grid">
        <article class="process-card reveal">
          <span>1</span>
          <h3>Escuchamos</h3>
          <p>Entendemos la empresa, el reto y el objetivo.</p>
        </article>
        <article class="process-card reveal delay-1">
          <span>2</span>
          <h3>Diagnosticamos</h3>
          <p>Detectamos fricción, desorden y oportunidades reales.</p>
        </article>
        <article class="process-card reveal delay-2">
          <span>3</span>
          <h3>Diseñamos</h3>
          <p>Definimos solución, arquitectura y experiencia.</p>
        </article>
        <article class="process-card reveal delay-3">
          <span>4</span>
          <h3>Implementamos</h3>
          <p>Construimos una solución clara, útil y profesional.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-contact" id="contacto">
    <div class="container contact-shell reveal visible">
      <div class="contact-copy">
        <span class="section-label dark">Contacto</span>
        <h2>Cuéntanos qué quieres optimizar</h2>
        <p>Si tu empresa necesita automatización con IA, integración de procesos o una página web premium adaptada a su servicio, podemos ayudarte.</p>
        <ul class="contact-list" role="list">
          <li>Automatización con IA.</li>
          <li>Integración de herramientas.</li>
          <li>Páginas web personalizadas.</li>
          <li>Correo: <a href="mailto:olai.digital.mx@gmail.com">olai.digital.mx@gmail.com</a></li>
        </ul>
      </div>

      <div class="contact-form-box">
        {% form 'contact', class: 'contact-form' %}
          <div class="field-row">
            <input type="text" name="contact[name]" placeholder="Nombre" required>
            <input type="email" name="contact[email]" placeholder="Correo" required>
          </div>
          <input type="text" name="contact[company]" placeholder="Empresa">
          <textarea name="contact[body]" placeholder="Cuéntanos qué necesitas" required></textarea>
          <button type="submit" class="btn btn-dark full">Enviar solicitud</button>
          {% if form.posted_successfully? %}
            <p class="form-message success">Gracias, recibimos tu mensaje.</p>
          {% endif %}
          {% if form.errors %}
            <p class="form-message error">Revisa los datos e inténtalo de nuevo.</p>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </section>
</section>

{% schema %}
{
  "name": "OLAI home",
  "settings": [],
  "presets": [
    { "name": "OLAI home" }
  ]
}
{% endschema %}